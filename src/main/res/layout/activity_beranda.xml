<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvJudulBeranda"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Beranda - Sistem Kasir / Toko Digital"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/imgProduk"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="12dp"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/tvInfoProduk"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Daftar Produk Tersedia"
            android:textSize="16sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnScanProduk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Scan Produk" />

    <Button
        android:id="@+id/btnInputTransaksi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Input Transaksi" />

    <Button
        android:id="@+id/btnLihatLaporan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lihat Laporan Penjualan" />

</LinearLayout>